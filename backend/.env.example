# =============================================================================
# SmartRecruitz Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.
# =============================================================================

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://sr_user:sr_password@localhost:5432/smartrecruitz
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=3

# Coresignal (LinkedIn x Resume cross-check) — leave CORESIGNAL_API_KEY blank to disable
CORESIGNAL_API_KEY=
CORESIGNAL_BASE_URL=https://api.coresignal.com/cdapi/v2
CORESIGNAL_TIMEOUT_SECONDS=30

# File Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads
# S3 (production only)
# S3_BUCKET_NAME=smartrecruitz-uploads
# S3_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Security
API_KEY_SECRET=change-this-to-a-long-random-string
FIELD_ENCRYPTION_KEY=generate-a-base64-encoded-32-byte-key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=1000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Feature Flags
FEATURE_LMS_INTEGRATION=false
FEATURE_ATS_PUSH=false
FEATURE_WEBHOOK_OUTBOUND=false
